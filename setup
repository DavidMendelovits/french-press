#!/bin/bash
# french-press/setup — one-time install
# Makes /french-press available globally via ~/.claude/skills/french-press
#
# Usage:
#   ./setup                  # install globally
#   ./setup --check          # verify install only
#   ./setup --uninstall      # remove global symlink

set -euo pipefail

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
TARGET="$HOME/.claude/skills/french-press"

check_install() {
  if [ -f "$TARGET/SKILL.md" ]; then
    echo "✓ french-press is installed at $TARGET"
    if [ -L "$TARGET" ]; then
      echo "  (symlink → $(readlink "$TARGET"))"
    fi
    return 0
  else
    echo "✗ french-press is not installed globally"
    echo "  Run: $SKILL_DIR/setup"
    return 1
  fi
}

case "${1:-}" in
  --check)
    check_install
    exit $?
    ;;
  --uninstall)
    if [ -L "$TARGET" ]; then
      rm "$TARGET"
      echo "✓ Removed symlink at $TARGET"
    elif [ -d "$TARGET" ]; then
      echo "WARNING: $TARGET is a directory, not a symlink. Remove manually if you want to uninstall."
      exit 1
    else
      echo "Nothing to uninstall at $TARGET"
    fi
    exit 0
    ;;
esac

mkdir -p "$HOME/.claude/skills"

if [ -L "$TARGET" ]; then
  current=$(readlink "$TARGET")
  if [ "$current" = "$SKILL_DIR" ]; then
    echo "✓ Already installed: $TARGET → $SKILL_DIR"
    exit 0
  else
    echo "Updating symlink: $TARGET → $SKILL_DIR (was: $current)"
    rm "$TARGET"
  fi
elif [ -d "$TARGET" ]; then
  echo "ERROR: $TARGET exists and is not a symlink."
  echo "If it's an old install, remove it manually: rm -rf $TARGET"
  exit 1
fi

ln -s "$SKILL_DIR" "$TARGET"
echo "✓ Installed: $TARGET → $SKILL_DIR"
echo ""
echo "Now use /french-press in any Claude Code session to scaffold the agent."
